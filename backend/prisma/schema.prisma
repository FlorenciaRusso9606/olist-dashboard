generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["dwh"]
}

model DimDate {
  dateId     DateTime    @id @map("date_id") @db.Date
  year       Int
  quarter    Int
  month      Int
  monthName  String      @map("month_name")
  week       Int
  dayOfWeek  Int         @map("day_of_week")
  dayName    String      @map("day_name")
  isWeekend  Boolean     @map("is_weekend")
  factSales  FactSales[]

  @@map("dim_date")
  @@schema("dwh")
}

model DimCustomer {
  customerId            String      @id @map("customer_id")
  customerUniqueId      String      @map("customer_unique_id")
  customerCity          String?     @map("customer_city")
  customerState         String?     @map("customer_state")
  customerZipCodePrefix String?     @map("customer_zip_code_prefix")
  factSales             FactSales[]

  @@map("dim_customer")
  @@schema("dwh")
}

model DimProduct {
  productId                  String      @id @map("product_id")
  productCategoryName        String?     @map("product_category_name")
  productCategoryNameEnglish String?     @map("product_category_name_english")
  productWeightG             Decimal?    @map("product_weight_g")     @db.Decimal(10, 2)
  productVolumeCm3           Decimal?    @map("product_volume_cm3")   @db.Decimal(10, 2)
  factSales                  FactSales[]

  @@map("dim_product")
  @@schema("dwh")
}

model DimOrder {
  orderId                    String      @id @map("order_id")
  orderStatus                String      @map("order_status")
  orderPurchaseTimestamp     DateTime?   @map("order_purchase_timestamp")
  orderDeliveredCustomerDate DateTime?   @map("order_delivered_customer_date")
  orderEstimatedDeliveryDate DateTime?   @map("order_estimated_delivery_date")
  deliveryDays               Int?        @map("delivery_days")
  deliveryDelayDays          Int?        @map("delivery_delay_days")
  reviewScore                Int?        @map("review_score")
  factSales                  FactSales[]

  @@map("dim_order")
  @@schema("dwh")
}

model DimSeller {
  sellerId             String      @id @map("seller_id")
  sellerCity           String?     @map("seller_city")
  sellerState          String?     @map("seller_state")
  sellerZipCodePrefix  String?     @map("seller_zip_code_prefix")
  factSales            FactSales[]

  @@map("dim_seller")
  @@schema("dwh")
}

model FactSales {
  orderId               String   @map("order_id")
  orderItemId           Int      @map("order_item_id")
  dateId                DateTime @map("date_id")     @db.Date
  customerId            String   @map("customer_id")
  productId             String   @map("product_id")
  sellerId              String   @map("seller_id")
  itemPrice             Decimal  @map("item_price")              @db.Decimal(10, 2)
  freightValue          Decimal  @map("freight_value")           @db.Decimal(10, 2)
  paymentValueAllocated Decimal  @map("payment_value_allocated") @db.Decimal(10, 2)
  isDelivered           Boolean  @map("is_delivered")
  isCanceled            Boolean  @map("is_canceled")
  isOnTime              Boolean? @map("is_on_time")
  orderItemCount        Int      @map("order_item_count")
  paymentType           String?  @map("payment_type")
  paymentInstallments   Int?     @map("payment_installments")

  dimDate     DimDate     @relation(fields: [dateId],     references: [dateId])
  dimCustomer DimCustomer @relation(fields: [customerId], references: [customerId])
  dimProduct  DimProduct  @relation(fields: [productId],  references: [productId])
  dimOrder    DimOrder    @relation(fields: [orderId],     references: [orderId])
  dimSeller   DimSeller   @relation(fields: [sellerId],   references: [sellerId])

  @@id([orderId, orderItemId])
  @@map("fact_sales")
  @@schema("dwh")
}